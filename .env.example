# ============================================
# Spot VM 自动管理服务 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值

# --- 基础配置 ---
ENVIRONMENT=production
PORT=8080
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_KEY=your-super-secret-api-key-change-in-production

# --- 腾讯云凭证 ---
TENCENTCLOUD_SECRET_ID=your-secret-id
TENCENTCLOUD_SECRET_KEY=your-secret-key

# --- Region 和域名 ---
REGION=ap-hongkong
DOMAIN=example.com
CERTIFICATE_ID=your-certificate-id

# --- 实例创建配置 ---
IMAGE_ID=img-hdt9xxkt
INSTANCE_PASSWORD=your-instance-password
DISK_TYPE=CLOUD_BSSD
DISK_SIZE=20
BANDWIDTH=10

# --- SSH 和迁移配置 ---
SSH_PORT=22
SSH_TIMEOUT=10
SSH_WAIT_TIMEOUT=180
MIGRATION_MAX_RETRIES=3
REMOTE_BINARY_PATH=/opt/spot-manager/spot-manager
REMOTE_ENV_PATH=/opt/spot-manager/.env
